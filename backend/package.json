{
    "name": "auth-backend",
    "module": "App.ts",
    "private": true,
    "type": "module",
    "version": "2.0.0",
    "scripts": {
        "build": "tsc && tsc-alias",
        "start": "bun dist/App.js",
        "dev": "bun --watch --expose-gc ./src/App.ts",
        "clean": "rm -rf dist",
        "cleanup-tokens": "bun run src/utils/tokenCleanup.ts"
    },
    "dependencies": {
        "@upstash/ratelimit": "^2.0.8",
        "@upstash/redis": "^1.36.1",
        "bcrypt": "^6.0.0",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "express": "^4.22.1",
        "helmet": "^8.1.0",
        "jsonwebtoken": "^9.0.3",
        "mailtrap": "^4.4.0",
        "mongoose": "^8.21.1",
        "morgan": "^1.10.1",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@types/bcrypt": "^6.0.0",
        "@types/bun": "latest",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/morgan": "^1.9.10",
        "ts-node": "^10.9.2",
        "tsc-alias": "^1.8.16",
        "typescript": "^5.9.3"
    }
}
