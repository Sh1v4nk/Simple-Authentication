{
    "compilerOptions": {
        "baseUrl": "./",
        "paths": { "@/*": ["src/*"] },
        "target": "es2022",
        "module": "preserve",
        "moduleResolution": "bundler",
        "rootDir": "./src",
        "outDir": "./dist",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules"]
}
